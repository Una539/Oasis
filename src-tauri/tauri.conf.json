{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oasis",
  "version": "0.5.1",
  "identifier": "com.oasis.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Oasis",
        "width": 800,
        "height": 600,
        "minWidth": 550,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNEZFNDIyM0Y5REFENzgKUldSNHJaMC9JdVJQVVBHN1hnNEtXeHhha1NxRlB1Y3lEUVd4alZNamdUdUhjUVRVTnFibUQzU0UK",
      "endpoints": [
        "https://github.com/Una539/Oasis/releases/latest/download/latest.json"
      ]
    }
  }
}
